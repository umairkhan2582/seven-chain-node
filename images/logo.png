    <!-- 3. FAQPage — Platform-level FAQ (high-intent trading queries) -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is TheSeven.meme?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "TheSeven.meme is a crypto perpetual futures trading platform where you can long or short 100+ tokens — including Bitcoin, Ethereum, Dogecoin, Pepe, Solana, and Shiba Inu — with up to 2001x leverage on BSC and Ethereum, using live CoinGecko prices and instant execution."
          }
        },
        {
          "@type": "Question",
          "name": "How much leverage does The Seven offer?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The Seven offers up to 2001x leverage on all perpetual futures pairs. You can trade BTC, ETH, DOGE, PEPE and 96 more tokens with customizable leverage from 1x to 2001x, letting you control a position 2001 times larger than your collateral."
          }
        },
        {
          "@type": "Question",
          "name": "Do I need KYC to trade on TheSeven.meme?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No KYC is required. Simply connect your Web3 wallet (MetaMask, Trust Wallet, or any WalletConnect-compatible wallet) and start trading crypto perpetual futures instantly. Alternatively, create a platform wallet using just your email address."
          }
        },
        {
          "@type": "Question",
          "name": "Which cryptocurrencies can I trade on The Seven?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The Seven supports 100+ perpetual futures pairs including major cryptocurrencies (BTC, ETH, BNB, SOL, XRP, ADA), meme coins (DOGE, PEPE, SHIB, BONK, WIF, FLOKI, BRETT, POPCAT), and DeFi tokens (AAVE, UNI, LINK, CAKE, JUP). All prices are sourced live from CoinGecko."
          }
        },
        {
          "@type": "Question",
          "name": "What are perpetual futures?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Perpetual futures are derivative contracts that let you speculate on the price of a cryptocurrency without expiry. You can go long (bet the price rises) or short (bet the price falls) with leverage. Unlike traditional futures, perpetual contracts have no settlement date, so you can hold positions as long as you maintain sufficient margin."
          }
        },
        {
          "@type": "Question",
          "name": "What is the Seven/BNB token?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Seven/BNB is the native liquidity pool token of the platform, deployed on BNB Smart Chain at contract address 0x441c7b89b2dcb6a65f9e144b4d67bbe7b5494444. It is currently live on four.meme and entitles holders to a share of platform trading fees distributed in BNB (pre-launch) and later in USDT."
          }
        },
        {
          "@type": "Question",
          "name": "How are liquidations handled on The Seven?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Positions are liquidated automatically when your margin falls below the maintenance margin threshold. The liquidation price is calculated based on your entry price, position size, and leverage. Partial liquidations help protect traders from full position closure where possible."
          }
        },
        {
          "@type": "Question",
          "name": "What are the trading fees on TheSeven.meme?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The Seven charges a transparent fee on each trade. See the full fee schedule on our Fees page at theseven.meme/fees. Seven/BNB token holders may qualify for reduced trading fees and bonus rewards."
          }
        },
        {
          "@type": "Question",
          "name": "Is TheSeven.meme safe to use?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The Seven is a non-custodial platform — you connect your own Web3 wallet and retain control of your funds. All prices are sourced from CoinGecko live feeds, and the platform operates transparently on BSC and Ethereum. Always trade with funds you can afford to lose, as leveraged futures trading involves significant risk."
          }
        },
        {
          "@type": "Question",
          "name": "How do I convert crypto on The Seven?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Use the Convert tool at theseven.meme/convert to swap between cryptocurrencies. Get the best rates for pairs like BTC to USDT, ETH to BNB, DOGE to USDT, and more — instant conversion with live market rates."
          }
        }
      ]
    }
    </script>

